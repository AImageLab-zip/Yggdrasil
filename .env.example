DOCKER_SUFFIX=dev # or prod
ENV_FILE=.env

UID=$(id -u)
GID=$(id -g)

# Core app
SECRET_KEY=dev-secret-key-change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,web

# Optional proxy/HTTPS knobs
ENABLE_SSL=false
ENABLE_HTTPS_REDIRECT=false
FORCE_HTTPS=false
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Docker compose
WEB_EXTERNAL_PORT=9000
DB_EXTERNAL_PORT=4306
# MySQL (compose service: db)
MYSQL_DATABASE=yggdrasil
MYSQL_USER=toothfairy
MYSQL_PASSWORD=toothfairy_pass
MYSQL_ROOT_PASSWORD=root_pass_change_me

# Django DB settings
DB_NAME=yggdrasil
DB_USER=toothfairy
DB_PASSWORD=toothfairy_pass
DB_HOST=toothfairy4m-db-$DOCKER_SUFFIX
DB_PORT=3306

# Email backend (console for dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=noreply@yggdrasil.local
EMAIL_HOST_USERS=noreply@yggdrasil.local
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=noreply@yggdrasil.local

# Object storage
OBJECT_STORAGE_ENDPOINT_URL=http://garage:3900
OBJECT_STORAGE_REGION=garage
OBJECT_STORAGE_ACCESS_KEY_ID=tf4m-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=tf4m-secret-key
OBJECT_STORAGE_BUCKET=yggdrasil
OBJECT_STORAGE_USE_SSL=false
OBJECT_STORAGE_VERIFY_SSL=false
OBJECT_STORAGE_ADDRESSING_STYLE=path
OBJECT_STORAGE_KEY_PREFIX=

# Distributed runner (Celery + Redis)
REDIS_PASSWORD=change-me-redis-password
REDIS_EXTERNAL_PORT=6379
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_BROKER_DB=0
# REDIS_RESULT_DB=0
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=
CELERY_TIMEZONE=UTC
RUNNER_TASK_NAME=toothfairy4m_runner.process_job
RUNNER_DEFAULT_QUEUE=runner_dev
RUNNER_QUEUE_BY_MODALITY={"ios":"runner_ios_dev","bite_classification":"runner_bite_dev","cbct":"runner_cbct_dev","audio":"runner_audio_dev","voice":"runner_audio_dev"}
RUNNER_QUEUE_BY_PROJECT={}
RUNNER_API_TOKENS=dev-runner-token

# Logging
LOG_LEVEL=DEBUG

# Optional reverse-proxy metadata
DOMAIN=
LETSENCRYPT_EMAIL=
# VIRTUAL_HOST=         # defaults to DOMAIN
# VIRTUAL_PORT=8000
# LETSENCRYPT_HOST=     # defaults to VIRTUAL_HOST/DOMAIN

# Laparoscopy worker (optional — falls back to request host if unset)
# WORKER_BASE_URL=
# WORKER_SESSION_READY_URL=
# WORKER_SESSION_PROMPT_URL=
